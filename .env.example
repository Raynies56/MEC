# ═══════════════════════════════════════════════════
# MEC — CONFIGURACIÓN DE ENTORNO
# Copia este archivo a .env.local y completa los valores
# ═══════════════════════════════════════════════════

# SUPABASE (Base de Datos y Auth)
# URL del proyecto de Supabase (ej: https://xyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here

# Anon Key (para uso en el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service Role Key (SOLO PARA EL SERVIDOR - NUNCA EXPOSICIÓN AL CLIENTE)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# AUTH (Iron Session)
# Password para cifrar la cookie de sesión (mínimo 32 caracteres)
SESSION_PASSWORD=at_least_32_characters_long_password_here

# SEED DATA (scripts/seed-doctor.js)
# Email inicial de la administradora
SEED_ADMIN_EMAIL=doctora@visionplena.com.do
# Contraseña inicial de la administradora (cambiar en producción)
SEED_ADMIN_PASSWORD=your_secure_initial_password_here

# RECAPTCHA (Opcional - para formularios públicos)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
